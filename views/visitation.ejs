<%- include('partials-nav', { activeTab }) %>

<div class="row g-3 visitation-layout">
  <div class="col-12 col-lg-3" id="visitationSidebarCol">
    <div class="card mb-3 sticky-card visitation-sidebar">
      <div class="card-header"><h3 class="card-title">Folders</h3></div>
      <div class="card-body">
        <form id="folderForm" class="row g-2 mb-3">
          <div class="col-8">
            <input class="form-control" id="folderName" placeholder="Add folder" required />
          </div>
          <div class="col-4">
            <input class="form-control form-control-color w-100" id="folderColor" type="color" value="#20c997" />
          </div>
          <div class="col-12">
            <button type="submit" class="btn btn-success w-100">Add Folder</button>
          </div>
        </form>

        <div class="btn-group w-100 mb-3" role="group" aria-label="Map list toggle">
          <button type="button" class="btn btn-primary" data-mode="map">Map</button>
          <button type="button" class="btn btn-outline-primary" data-mode="list">List</button>
        </div>

        <div class="folder-filter-actions mb-2">
          <button type="button" class="btn btn-outline-secondary btn-sm w-100" id="showAllFolders">All Folders</button>
        </div>
        <div id="foldersList"></div>
      </div>
    </div>
  </div>

  <div class="col-12 col-lg-9" id="visitationMainCol">
    <div class="card mb-3 visitation-secondary-card">
      <div class="card-header"><h3 class="card-title">Territory Builder</h3></div>
      <div class="card-body">
        <p class="text-secondary mb-3">Draw map areas, organize by folder, and track claim status + checklist. Base map location comes from Church Settings.</p>
        <form id="sectionForm" class="row g-2">
          <input type="hidden" id="sectionId" />
          <div class="col-12 col-md-4">
            <label class="form-label">Section Name</label>
            <input class="form-control" id="sectionName" required placeholder="North-1" />
          </div>
          <div class="col-6 col-md-3">
            <label class="form-label">Folder</label>
            <select class="form-select" id="sectionFolder">
              <option value="">Unassigned</option>
            </select>
          </div>
          <div class="col-6 col-md-2">
            <label class="form-label">Color</label>
            <input class="form-control form-control-color" id="sectionColor" type="color" value="#0c4a6e" />
          </div>
          <div class="col-6 col-md-3">
            <label class="form-label">Status</label>
            <select class="form-select" id="sectionStatus">
              <option value="unclaimed">Unclaimed</option>
              <option value="claimed">Claimed</option>
              <option value="completed">Completed</option>
            </select>
          </div>
          <div class="col-6 col-md-3">
            <label class="form-label">Last Visited</label>
            <input class="form-control" id="sectionDate" type="date" />
          </div>
          <div class="col-6 col-md-3">
            <label class="form-label">Claimed By</label>
            <input class="form-control" id="sectionClaimedBy" placeholder="Volunteer name" />
          </div>
          <div class="col-6 col-md-3">
            <label class="form-label">Draw Mode</label>
            <select class="form-select" id="drawingTarget">
              <option value="section">Section Outline (Red)</option>
              <option value="street">Street Layer (Green)</option>
            </select>
          </div>
          <div class="col-12 col-md-3">
            <label class="form-label">Street Name</label>
            <input class="form-control" id="streetName" placeholder="Rua Recife - Block A" />
          </div>
          <div class="col-12 col-md-6">
            <label class="form-label">Checklist (one item per line)</label>
            <textarea class="form-control" id="sectionChecklist" rows="2" placeholder="Knock doors&#10;Pray with family&#10;Leave flyer"></textarea>
          </div>
          <div class="col-12">
            <label class="form-label">Notes</label>
            <textarea class="form-control" id="sectionNotes" rows="2"></textarea>
          </div>
          <div class="col-12">
            <label class="form-label">Streets In This Section</label>
            <div class="street-draft-list" id="streetDraftList">
              <p class="text-secondary mb-0">Switch Draw Mode to Street Layer and draw green areas inside the section.</p>
            </div>
            <p class="text-secondary mt-2 mb-0">
              Steps: draw the red section first, switch to green street mode, draw street blocks, then save section.
            </p>
          </div>
          <div class="col-12 d-flex align-items-end gap-2">
            <button type="submit" class="btn btn-primary">Save Section</button>
            <button type="button" class="btn btn-outline-secondary" id="clearDrawing">Clear Draft</button>
          </div>
        </form>
      </div>
    </div>

    <div class="card mb-3 visitation-secondary-card">
      <div class="card-header"><h3 class="card-title">Field Claim Mode (Mobile)</h3></div>
      <div class="card-body">
        <div class="row g-2">
          <div class="col-12 col-md-5">
            <label class="form-label">Worker Name</label>
            <input class="form-control" id="claimWorkerName" placeholder="Your name" />
          </div>
          <div class="col-12 col-md-4 d-flex align-items-end">
            <button type="button" class="btn btn-success w-100" id="claimNearest">Claim Selected / Nearest</button>
          </div>
          <div class="col-12">
            <p class="text-secondary mb-0" id="locationHint">Claiming uses church map base + current map view (no phone location needed).</p>
          </div>
        </div>
      </div>
    </div>

    <div class="card visitation-map-card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title mb-0">Territory Board</h3>
        <span class="badge bg-azure-lt" id="activeFolderLabel">All Folders</span>
      </div>
      <div class="card-body">
        <div id="mapWrap">
          <div class="map-top-controls">
            <div class="map-top-left">
              <div class="btn-group btn-group-sm map-layer-toggle" role="group" aria-label="Map style">
                <button type="button" class="btn btn-light" id="mapStyleMapBtn">Map</button>
                <button type="button" class="btn btn-light active" id="mapStyleSatelliteBtn">Satellite</button>
              </div>
              <div class="btn-group btn-group-sm map-tools" role="group" aria-label="Map tools">
                <button type="button" class="btn btn-light" id="toggleFoldersBtn" title="Show folders">
                  <i class="bi bi-folder2-open"></i>
                </button>
                <button type="button" class="btn btn-light" id="addMarkerBtn" title="Add marker">
                  <i class="bi bi-geo-alt"></i>
                </button>
                <button type="button" class="btn btn-light" id="addMapBtn" title="Add map">
                  <i class="bi bi-bounding-box"></i>
                </button>
                <button type="button" class="btn btn-light active" id="toggleMapNamesBtn" title="Show map names">
                  <i class="bi bi-tag"></i>
                </button>
              </div>
            </div>
            <div class="map-top-right">
              <input class="form-control form-control-sm" id="mapSearchInput" placeholder="Search Location" />
            </div>
          </div>
          <div id="map"></div>
        </div>
        <div id="listWrap" class="d-none"><div id="sectionsList"></div></div>
      </div>
    </div>
  </div>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet-draw@1.0.4/dist/leaflet.draw.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet-draw@1.0.4/dist/leaflet.draw.js"></script>
<script>
  window.__VISITATION_BOOTSTRAP__ = <%- JSON.stringify({ sections, folders, markers, mapSettings, mapProfiles }) %>;
</script>
<script src="/static/js/visitation.js?v=20260421c"></script>

<%- include('partials-footer') %>
