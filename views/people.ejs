<%- include('partials-nav', { activeTab }) %>

<div class="row g-3">
  <div class="col-12 col-lg-9">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">People Directory</h3>
        <div class="card-actions d-flex gap-2">
          <span class="badge bg-secondary-lt">
            <%= totalFilteredPeople ? `Showing ${pageRangeStart}-${pageRangeEnd} of ${totalFilteredPeople} people` : '0 people' %>
          </span>
          <a class="btn btn-primary btn-sm" href="/people/new">+ Person</a>
        </div>
      </div>
      <div class="card-body border-bottom">
        <form method="get" action="/people" class="row g-2">
          <div class="col-12 col-md-3">
            <label class="form-label">Search</label>
            <input class="form-control" name="q" value="<%= q || '' %>" placeholder="Name, phone, email, section, notes" />
          </div>
          <div class="col-12 col-md-2">
            <label class="form-label">Follow-up Filter</label>
            <select class="form-select" name="followups">
              <option value="all" <%= followups === 'all' ? 'selected' : '' %>>All people</option>
              <option value="open" <%= followups === 'open' ? 'selected' : '' %>>Only with open follow-ups</option>
            </select>
          </div>
          <div class="col-12 col-md-2">
            <label class="form-label">Membership</label>
            <select class="form-select" name="membershipType">
              <option value="">Any</option>
              <% membershipTypes.forEach((type) => { %>
                <option value="<%= type %>" <%= membershipTypeFilter === type ? 'selected' : '' %>><%= type %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-12 col-md-2">
            <label class="form-label">Tag</label>
            <input class="form-control" name="tag" value="<%= tagFilter || '' %>" list="peopleTagsList" placeholder="Any tag" />
            <datalist id="peopleTagsList">
              <% availableTags.forEach((tag) => { %>
                <option value="<%= tag %>"></option>
              <% }) %>
            </datalist>
          </div>
          <div class="col-12 col-md-1">
            <label class="form-label">Per Page</label>
            <select class="form-select" name="perPage">
              <% pageSizeOptions.forEach((size) => { %>
                <option value="<%= size %>" <%= pageSize === size ? 'selected' : '' %>><%= size %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-12 col-md-2 d-flex align-items-end gap-2">
            <button type="submit" class="btn btn-outline-primary w-100">Apply</button>
            <a class="btn btn-outline-secondary" href="/people">Clear</a>
          </div>
        </form>
        <form method="post" action="/people/filters" class="row g-2 mt-1">
          <input type="hidden" name="q" value="<%= q || '' %>" />
          <input type="hidden" name="followups" value="<%= followups || 'all' %>" />
          <input type="hidden" name="membershipType" value="<%= membershipTypeFilter || '' %>" />
          <input type="hidden" name="tag" value="<%= tagFilter || '' %>" />
          <div class="col-12 col-md-4">
            <label class="form-label">Save This Smart Filter</label>
            <input class="form-control" name="name" placeholder="Ex: Open Prospect Follow-ups" required />
          </div>
          <div class="col-12 col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-outline-primary w-100">Save Filter</button>
          </div>
          <% if (selectedSmartFilterName) { %>
            <div class="col-12 col-md-6 d-flex align-items-end">
              <span class="badge bg-azure-lt">Active Smart Filter: <%= selectedSmartFilterName %></span>
            </div>
          <% } %>
        </form>
      </div>

      <div class="table-responsive">
        <table class="table table-vcenter">
          <thead>
            <tr>
              <th>Name</th>
              <th>Contact</th>
              <th>Birthday</th>
              <th>Type</th>
              <th>Tags</th>
              <th>Open Follow-ups</th>
              <th class="w-1"></th>
            </tr>
          </thead>
          <tbody>
            <% if (!people.length) { %>
              <tr><td colspan="7" class="text-secondary">No people added yet.</td></tr>
            <% } %>

            <% people.forEach((person) => { %>
              <tr>
                <td>
                  <div class="fw-semibold"><%= person.name %></div>
                  <div class="text-secondary">Profile <%= person.profilePercent %>% complete</div>
                </td>
                <td>
                  <div><%= person.phone || '-' %></div>
                  <div class="text-secondary"><%= person.email || '-' %></div>
                </td>
                <td><%= person.birthday ? formatDateDMY(person.birthday) : '-' %></td>
                <td>
                  <span class="badge bg-azure-lt"><%= person.membershipType || 'Prospect' %></span>
                </td>
                <td>
                  <% if ((person.tags || []).length) { %>
                    <div class="d-flex flex-wrap gap-1">
                      <% person.tags.forEach((tag) => { %>
                        <span class="badge bg-secondary-lt"><%= tag %></span>
                      <% }) %>
                    </div>
                  <% } else { %>
                    <span class="text-secondary">-</span>
                  <% } %>
                </td>
                <td><span class="badge <%= person.openFollowUps ? 'bg-red-lt' : 'bg-green-lt' %>"><%= person.openFollowUps %></span></td>
                <td>
                  <a class="btn btn-primary btn-sm" href="/people/<%= person.id %>">Open</a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <div class="card-footer d-flex align-items-center">
        <p class="m-0 text-secondary">Page <%= currentPage %> of <%= totalPages %> · <%= pageSize %> per page</p>
        <ul class="pagination m-0 ms-auto">
          <li class="page-item <%= previousPageUrl ? '' : 'disabled' %>">
            <a class="page-link" href="<%= previousPageUrl || '#' %>" aria-disabled="<%= previousPageUrl ? 'false' : 'true' %>">Previous</a>
          </li>
          <% paginationLinks.forEach((pageLink) => { %>
            <li class="page-item <%= pageLink.isCurrent ? 'active' : '' %>">
              <a class="page-link" href="<%= pageLink.url %>"><%= pageLink.number %></a>
            </li>
          <% }) %>
          <li class="page-item <%= nextPageUrl ? '' : 'disabled' %>">
            <a class="page-link" href="<%= nextPageUrl || '#' %>" aria-disabled="<%= nextPageUrl ? 'false' : 'true' %>">Next</a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="col-12 col-lg-3">
    <div class="card mb-3">
      <div class="card-header"><h3 class="card-title">Upcoming Birthdays</h3></div>
      <div class="list-group list-group-flush">
        <% if (!upcomingBirthdays.length) { %>
          <div class="list-group-item text-secondary">No birthdays found.</div>
        <% } %>
        <% upcomingBirthdays.forEach((item) => { %>
          <a class="list-group-item list-group-item-action" href="/people/<%= item.id %>">
            <div class="d-flex justify-content-between">
              <strong><%= item.name %></strong>
              <span class="text-secondary"><%= item.daysUntil === 0 ? 'Today' : item.daysUntil + 'd' %></span>
            </div>
            <div class="text-secondary"><%= formatDateDMY(item.nextBirthdayIso) %></div>
          </a>
        <% }) %>
      </div>
    </div>

    <div class="card mb-3">
      <div class="card-header"><h3 class="card-title">Smart Filters</h3></div>
      <div class="list-group list-group-flush">
        <% if (!savedPeopleFilters.length) { %>
          <div class="list-group-item text-secondary">No saved filters yet.</div>
        <% } %>
        <% savedPeopleFilters.forEach((filter) => { %>
          <div class="list-group-item">
            <div class="d-flex justify-content-between align-items-center gap-2">
              <a href="/people?smartFilter=<%= filter.id %>" class="fw-semibold text-decoration-none"><%= filter.name %></a>
              <form method="post" action="/people/filters/<%= filter.id %>/delete" onsubmit="return confirm('Delete this smart filter?');">
                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
              </form>
            </div>
            <div class="text-secondary small mt-1">
              <% if (filter.q) { %>Search: "<%= filter.q %>" · <% } %>
              <% if (filter.membershipType) { %>Type: <%= filter.membershipType %> · <% } %>
              <% if (filter.tag) { %>Tag: <%= filter.tag %> · <% } %>
              Follow-ups: <%= filter.followups === 'open' ? 'Open only' : 'All' %>
            </div>
          </div>
        <% }) %>
      </div>
    </div>

    <div class="card">
      <div class="card-header"><h3 class="card-title">Quick Actions</h3></div>
      <div class="card-body d-grid gap-2">
        <a class="btn btn-outline-primary" href="/people/new">+ Add Person</a>
        <a class="btn btn-outline-secondary" href="/import">Import People</a>
      </div>
    </div>
  </div>
</div>

<%- include('partials-footer') %>
