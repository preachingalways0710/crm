<%- include('partials-nav', { activeTab }) %>

<div class="row g-3">
  <div class="col-12 col-lg-9">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">People Directory</h3>
        <div class="card-actions d-flex gap-2">
          <span class="badge bg-secondary-lt"><%= people.length %> people</span>
          <a class="btn btn-primary btn-sm" href="/people/new">+ Person</a>
        </div>
      </div>
      <div class="card-body border-bottom">
        <form method="get" action="/people" class="row g-2">
          <div class="col-12 col-md-6">
            <label class="form-label">Search</label>
            <input class="form-control" name="q" value="<%= q || '' %>" placeholder="Name, phone, email, section, notes" />
          </div>
          <div class="col-12 col-md-4">
            <label class="form-label">Follow-up Filter</label>
            <select class="form-select" name="followups">
              <option value="all" <%= followups === 'all' ? 'selected' : '' %>>All people</option>
              <option value="open" <%= followups === 'open' ? 'selected' : '' %>>Only with open follow-ups</option>
            </select>
          </div>
          <div class="col-12 col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-outline-primary w-100">Apply</button>
          </div>
        </form>
      </div>

      <div class="table-responsive">
        <table class="table table-vcenter">
          <thead>
            <tr>
              <th>Name</th>
              <th>Contact</th>
              <th>Birthday</th>
              <th>Type</th>
              <th>Open Follow-ups</th>
              <th class="w-1"></th>
            </tr>
          </thead>
          <tbody>
            <% if (!people.length) { %>
              <tr><td colspan="6" class="text-secondary">No people added yet.</td></tr>
            <% } %>

            <% people.forEach((person) => { %>
              <tr>
                <td>
                  <div class="fw-semibold"><%= person.name %></div>
                  <div class="text-secondary">Profile <%= person.profilePercent %>% complete</div>
                </td>
                <td>
                  <div><%= person.phone || '-' %></div>
                  <div class="text-secondary"><%= person.email || '-' %></div>
                </td>
                <td><%= person.birthday ? formatDateDMY(person.birthday) : '-' %></td>
                <td>
                  <span class="badge bg-azure-lt"><%= person.membershipType || 'Prospect' %></span>
                </td>
                <td><span class="badge <%= person.openFollowUps ? 'bg-red-lt' : 'bg-green-lt' %>"><%= person.openFollowUps %></span></td>
                <td>
                  <a class="btn btn-primary btn-sm" href="/people/<%= person.id %>">Open</a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="col-12 col-lg-3">
    <div class="card mb-3">
      <div class="card-header"><h3 class="card-title">Upcoming Birthdays</h3></div>
      <div class="list-group list-group-flush">
        <% if (!upcomingBirthdays.length) { %>
          <div class="list-group-item text-secondary">No birthdays found.</div>
        <% } %>
        <% upcomingBirthdays.forEach((item) => { %>
          <a class="list-group-item list-group-item-action" href="/people/<%= item.id %>">
            <div class="d-flex justify-content-between">
              <strong><%= item.name %></strong>
              <span class="text-secondary"><%= item.daysUntil === 0 ? 'Today' : item.daysUntil + 'd' %></span>
            </div>
            <div class="text-secondary"><%= formatDateDMY(item.nextBirthdayIso) %></div>
          </a>
        <% }) %>
      </div>
    </div>

    <div class="card">
      <div class="card-header"><h3 class="card-title">Quick Actions</h3></div>
      <div class="card-body d-grid gap-2">
        <a class="btn btn-outline-primary" href="/people/new">+ Add Person</a>
        <a class="btn btn-outline-secondary" href="/import">Import People</a>
      </div>
    </div>
  </div>
</div>

<%- include('partials-footer') %>
