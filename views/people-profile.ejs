<%- include('partials-nav', { activeTab }) %>

<div class="mb-3">
  <a href="/people" class="btn btn-ghost-secondary btn-sm"><i class="bi bi-arrow-left"></i> Back to People</a>
</div>

<div class="row g-3">
  <div class="col-12 col-lg-3">
    <div class="card sticky-card">
      <div class="card-body text-center">
        <span class="avatar avatar-xl mb-3"><%= person.name?.charAt(0)?.toUpperCase() || '?' %></span>
        <h3 class="m-0"><%= person.name %></h3>
        <p class="text-secondary mb-2"><%= person.email || 'No email' %></p>
        <span class="badge bg-green-lt">Active</span>
        <span class="badge bg-azure-lt"><%= person.membershipType || 'Prospect' %></span>
      </div>

      <div class="list-group list-group-flush">
        <a class="list-group-item list-group-item-action" href="/people/<%= person.id %>?tab=profile"><i class="bi bi-person me-2"></i>Profile</a>
        <a class="list-group-item list-group-item-action" href="/people/<%= person.id %>?tab=followups"><i class="bi bi-list-check me-2"></i>Follow-ups</a>
        <a class="list-group-item list-group-item-action" href="/people/<%= person.id %>?tab=visits"><i class="bi bi-calendar-check me-2"></i>Visit Log</a>
        <a class="list-group-item list-group-item-action" href="/people/<%= person.id %>?tab=notes"><i class="bi bi-journal-text me-2"></i>Notes</a>
      </div>

      <div class="card-body border-top d-grid gap-2">
        <a class="btn btn-outline-primary" href="/people/<%= person.id %>?tab=followups">Add follow-up</a>
        <a class="btn btn-outline-primary" href="/people/<%= person.id %>?tab=visits">Log visit</a>
        <form method="post" action="/people/<%= person.id %>/delete" onsubmit="return confirm('Delete this person?');">
          <button type="submit" class="btn btn-outline-danger w-100">Delete person</button>
        </form>
      </div>
    </div>
  </div>

  <div class="col-12 col-lg-9">
    <div class="card mb-3">
      <div class="card-body">
        <ul class="nav nav-pills">
          <li class="nav-item"><a class="nav-link <%= tab === 'profile' ? 'active' : '' %>" href="/people/<%= person.id %>?tab=profile">Profile</a></li>
          <li class="nav-item"><a class="nav-link <%= tab === 'followups' ? 'active' : '' %>" href="/people/<%= person.id %>?tab=followups">Follow-ups</a></li>
          <li class="nav-item"><a class="nav-link <%= tab === 'visits' ? 'active' : '' %>" href="/people/<%= person.id %>?tab=visits">Visits</a></li>
          <li class="nav-item"><a class="nav-link <%= tab === 'notes' ? 'active' : '' %>" href="/people/<%= person.id %>?tab=notes">Notes</a></li>
        </ul>
      </div>
    </div>

    <% if (tab === 'profile') { %>
      <div class="row g-3 mb-3">
        <div class="col-12 col-md-4">
          <div class="card">
            <div class="card-body">
              <div class="text-secondary">Open follow-ups</div>
              <div class="display-6"><%= followUpOpenCount %></div>
            </div>
          </div>
        </div>
        <div class="col-12 col-md-4">
          <div class="card">
            <div class="card-body">
              <div class="text-secondary">Total visits</div>
              <div class="display-6"><%= visits.length %></div>
            </div>
          </div>
        </div>
        <div class="col-12 col-md-4">
          <div class="card">
            <div class="card-body">
              <div class="text-secondary">Profile complete</div>
              <div class="display-6"><%= person.profilePercent %>%</div>
            </div>
          </div>
        </div>
      </div>

      <form method="post" action="/people/<%= person.id %>">
        <input type="hidden" name="returnTo" value="/people/<%= person.id %>?tab=profile" />

        <div class="row g-3">
          <div class="col-12 col-md-6">
            <div class="card">
              <div class="card-header"><h3 class="card-title">Personal Details</h3></div>
              <div class="card-body row g-2">
                <div class="col-12"><label class="form-label">Full Name</label><input class="form-control" name="name" value="<%= person.name || '' %>" required /></div>
                <div class="col-6">
                  <label class="form-label">Gender</label>
                  <select class="form-select" name="gender">
                    <% genderOptions.forEach((option) => { %>
                      <option value="<%= option %>" <%= person.gender === option ? 'selected' : '' %>><%= option %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-6"><label class="form-label">Age Group</label><input class="form-control" name="ageGroup" value="<%= person.ageGroup || '' %>" /></div>
                <div class="col-6"><label class="form-label">Birthday (dd/mm/yyyy)</label><input class="form-control" id="birthdayInput" name="birthday" placeholder="27/09/2009" value="<%= person.birthday ? formatDateDMY(person.birthday) : '' %>" /></div>
                <div class="col-6"><label class="form-label">Age</label><input class="form-control" id="ageLive" value="<%= person.age ?? '-' %>" disabled /></div>
              </div>
            </div>
          </div>

          <div class="col-12 col-md-6">
            <div class="card">
              <div class="card-header"><h3 class="card-title">Contact Details</h3></div>
              <div class="card-body row g-2">
                <div class="col-12"><label class="form-label">Email</label><input class="form-control" name="email" value="<%= person.email || '' %>" /></div>
                <div class="col-12"><label class="form-label">Phone</label><input class="form-control" name="phone" value="<%= person.phone || '' %>" /></div>
                <div class="col-12"><label class="form-label">Address</label><input class="form-control" name="address" value="<%= person.address || '' %>" /></div>
                <div class="col-4"><label class="form-label">City</label><input class="form-control" name="city" value="<%= person.city || '' %>" /></div>
                <div class="col-4"><label class="form-label">State</label><input class="form-control" name="state" value="<%= person.state || '' %>" /></div>
                <div class="col-4"><label class="form-label">Zip</label><input class="form-control" name="zipCode" value="<%= person.zipCode || '' %>" /></div>
              </div>
            </div>
          </div>

          <div class="col-12 col-md-6">
            <div class="card">
              <div class="card-header"><h3 class="card-title">Additional Details</h3></div>
              <div class="card-body row g-2">
                <div class="col-6">
                  <label class="form-label">Membership Type</label>
                  <select class="form-select" name="membershipType">
                    <% membershipTypes.forEach((type) => { %>
                      <option value="<%= type %>" <%= (person.membershipType || 'Prospect') === type ? 'selected' : '' %>><%= type %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-6"><label class="form-label">Section ID</label><input class="form-control" name="sectionId" value="<%= person.sectionId || '' %>" /></div>
                <div class="col-6"><label class="form-label">Occupation</label><input class="form-control" name="occupation" value="<%= person.occupation || '' %>" /></div>
                <div class="col-6"><label class="form-label">Language</label><input class="form-control" name="language" value="<%= person.language || '' %>" /></div>
                <div class="col-6"><label class="form-label">Marital Status</label><input class="form-control" name="maritalStatus" value="<%= person.maritalStatus || '' %>" /></div>
              </div>
            </div>
          </div>

          <div class="col-12 col-md-6">
            <div class="card">
              <div class="card-header"><h3 class="card-title">Health Details</h3></div>
              <div class="card-body row g-2">
                <div class="col-12"><label class="form-label">Allergies</label><input class="form-control" name="allergies" value="<%= person.allergies || '' %>" /></div>
                <div class="col-12"><label class="form-label">Emergency Contact</label><input class="form-control" name="emergencyContact" value="<%= person.emergencyContact || '' %>" /></div>
                <div class="col-12"><label class="form-label">Medical Notes</label><textarea class="form-control" name="medicalNotes" rows="3"><%= person.medicalNotes || '' %></textarea></div>
              </div>
            </div>
          </div>

          <div class="col-12">
            <button class="btn btn-primary" type="submit">Save Profile</button>
          </div>
        </div>
      </form>
    <% } %>

    <% if (tab === 'followups') { %>
      <div class="card mb-3">
        <div class="card-header"><h3 class="card-title">Add Follow-up</h3></div>
        <div class="card-body">
          <form method="post" action="/people/<%= person.id %>/followups" class="row g-2">
            <div class="col-12 col-md-5"><label class="form-label">Task</label><input class="form-control" name="title" required placeholder="Call this week" /></div>
            <div class="col-12 col-md-3"><label class="form-label">Due Date</label><input class="form-control" name="dueDate" type="date" /></div>
            <div class="col-12 col-md-4"><label class="form-label">Notes</label><input class="form-control" name="notes" placeholder="Prayer request follow-up" /></div>
            <div class="col-12"><button class="btn btn-primary" type="submit">Add Follow-up</button></div>
          </form>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><h3 class="card-title">Follow-up Queue</h3></div>
        <div class="table-responsive">
          <table class="table table-vcenter">
            <thead><tr><th>Task</th><th>Due</th><th>Status</th><th>Notes</th><th class="w-1"></th></tr></thead>
            <tbody>
              <% if (!followUps.length) { %>
                <tr><td colspan="5" class="text-secondary">No follow-ups yet.</td></tr>
              <% } %>
              <% followUps.forEach((item) => { %>
                <tr>
                  <td><%= item.title %></td>
                  <td><%= item.dueDate || '-' %></td>
                  <td>
                    <span class="badge <%= item.status === 'completed' ? 'bg-green-lt' : 'bg-orange-lt' %>"><%= item.status %></span>
                  </td>
                  <td><%= item.notes || '-' %></td>
                  <td>
                    <% if (item.status === 'completed') { %>
                      <form method="post" action="/people/<%= person.id %>/followups/<%= item.id %>/reopen"><button class="btn btn-sm" type="submit">Reopen</button></form>
                    <% } else { %>
                      <form method="post" action="/people/<%= person.id %>/followups/<%= item.id %>/complete"><button class="btn btn-primary btn-sm" type="submit">Complete</button></form>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>

    <% if (tab === 'visits') { %>
      <div class="card mb-3">
        <div class="card-header"><h3 class="card-title">Log Visit</h3></div>
        <div class="card-body">
          <form method="post" action="/people/<%= person.id %>/visits" class="row g-2">
            <div class="col-12 col-md-3"><label class="form-label">Date</label><input class="form-control" name="date" type="date" value="<%= new Date().toISOString().slice(0, 10) %>" /></div>
            <div class="col-12 col-md-5"><label class="form-label">Summary</label><input class="form-control" name="summary" required placeholder="Home visit with prayer" /></div>
            <div class="col-12 col-md-4"><label class="form-label">Next Step</label><input class="form-control" name="nextStep" placeholder="Call on Friday" /></div>
            <div class="col-12"><button class="btn btn-primary" type="submit">Save Visit</button></div>
          </form>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><h3 class="card-title">Visit Timeline</h3></div>
        <div class="list-group list-group-flush">
          <% if (!visits.length) { %>
            <div class="list-group-item text-secondary">No visits logged yet.</div>
          <% } %>
          <% visits.forEach((visit) => { %>
            <div class="list-group-item">
              <div class="d-flex justify-content-between">
                <strong><%= visit.summary %></strong>
                <span class="text-secondary"><%= visit.date %></span>
              </div>
              <p class="mb-0 text-secondary">Next step: <%= visit.nextStep || '-' %></p>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <% if (tab === 'notes') { %>
      <div class="card">
        <div class="card-header"><h3 class="card-title">Pastoral Notes</h3></div>
        <div class="card-body">
          <form method="post" action="/people/<%= person.id %>">
            <input type="hidden" name="returnTo" value="/people/<%= person.id %>?tab=notes" />

            <label class="form-label">Notes</label>
            <textarea class="form-control" name="notes" rows="8"><%= person.notes || '' %></textarea>
            <button class="btn btn-primary mt-3" type="submit">Save Notes</button>
          </form>
        </div>
      </div>
    <% } %>
  </div>
</div>

<script>
  (function () {
    const birthdayInput = document.getElementById('birthdayInput');
    const ageLive = document.getElementById('ageLive');
    if (!birthdayInput || !ageLive) return;

    function calcAgeFromDMY(value) {
      const match = (value || '').trim().match(/^(\\d{1,2})\\/(\\d{1,2})\\/(\\d{4})$/);
      if (!match) return '-';
      const day = Number(match[1]);
      const month = Number(match[2]);
      const year = Number(match[3]);
      const dob = new Date(year, month - 1, day);
      if (
        Number.isNaN(dob.getTime()) ||
        dob.getFullYear() !== year ||
        dob.getMonth() !== month - 1 ||
        dob.getDate() !== day
      ) {
        return '-';
      }

      const today = new Date();
      let age = today.getFullYear() - dob.getFullYear();
      const monthDiff = today.getMonth() - dob.getMonth();
      if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < dob.getDate())) {
        age -= 1;
      }
      return age >= 0 ? String(age) : '-';
    }

    function refreshAge() {
      ageLive.value = calcAgeFromDMY(birthdayInput.value);
    }

    birthdayInput.addEventListener('input', refreshAge);
    refreshAge();
  })();
</script>

<%- include('partials-footer') %>
