<%- include('partials-nav', { activeTab }) %>

<div class="row row-deck row-cards mb-3">
  <div class="col-sm-6 col-lg-3">
    <div class="card">
      <div class="card-body">
        <div class="text-secondary">Total People</div>
        <div class="display-6"><%= totalPeople %></div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-lg-3">
    <div class="card">
      <div class="card-body">
        <div class="text-secondary">Birthdays This Month</div>
        <div class="display-6"><%= birthdaysThisMonth %></div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-lg-3">
    <div class="card">
      <div class="card-body">
        <div class="text-secondary">Visits This Month</div>
        <div class="display-6"><%= visitsThisMonth %></div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-lg-3">
    <div class="card">
      <div class="card-body">
        <div class="text-secondary">Open Follow-ups</div>
        <div class="display-6"><%= openFollowUps %></div>
      </div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header"><h3 class="card-title">Metrics App</h3></div>
  <div class="card-body">
    <% if (metricsAppUrl) { %>
      <p class="text-secondary">
        Embedded from <code>METRICS_APP_URL</code> (fallback: <code>ATTENDANCE_APP_URL</code>).
      </p>
      <div class="mb-2">
        <a class="btn btn-outline-secondary btn-sm" href="<%= metricsAppUrl %>" target="_blank" rel="noopener noreferrer">Open in New Tab</a>
      </div>
      <iframe src="<%= metricsAppUrl %>" class="embed"></iframe>
    <% } else { %>
      <p class="text-secondary">Set <code>METRICS_APP_URL=https://pessoas.meuibbv.com</code> (or <code>ATTENDANCE_APP_URL</code>) in environment variables to embed your metrics app here.</p>
    <% } %>
  </div>
</div>

<%- include('partials-footer') %>
