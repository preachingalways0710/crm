<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Church Dashboard</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/css/tabler.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link rel="stylesheet" href="/static/styles.css" />
</head>
<body>
  <div class="page">
    <header class="navbar navbar-expand-md d-print-none">
      <div class="container-xl">
        <h1 class="navbar-brand navbar-brand-autodark d-none-navbar-horizontal pe-0 pe-md-3 m-0">Church Dashboard</h1>
        <div class="navbar-nav flex-row order-md-last">
          <div class="nav-item d-none d-md-flex me-3">
            <span class="badge bg-azure-lt">People + Calendar + Visits</span>
          </div>
          <% if (authEnabled && isAuthenticated) { %>
            <div class="nav-item">
              <form method="post" action="/logout">
                <button class="btn btn-sm btn-outline-secondary" type="submit">Log out</button>
              </form>
            </div>
          <% } %>
        </div>
      </div>
    </header>

    <header class="navbar-expand-md">
      <div class="collapse navbar-collapse" id="navbar-menu">
        <div class="navbar">
          <div class="container-xl">
            <ul class="navbar-nav">
              <li class="nav-item <%= activeTab === 'people' ? 'active' : '' %>"><a class="nav-link" href="/people"><span class="nav-link-title">People</span></a></li>
              <li class="nav-item <%= activeTab === 'people_new' ? 'active' : '' %>"><a class="nav-link" href="/people/new"><span class="nav-link-title">+ Person</span></a></li>
              <li class="nav-item <%= activeTab === 'followups' ? 'active' : '' %>"><a class="nav-link" href="/followups"><span class="nav-link-title">Follow-ups</span></a></li>
              <li class="nav-item <%= activeTab === 'metrics' ? 'active' : '' %>"><a class="nav-link" href="/metrics"><span class="nav-link-title">Metrics</span></a></li>
              <li class="nav-item <%= activeTab === 'calendar' ? 'active' : '' %>"><a class="nav-link" href="/calendar"><span class="nav-link-title">Calendar</span></a></li>
              <li class="nav-item <%= activeTab === 'forms' ? 'active' : '' %>"><a class="nav-link" href="/forms"><span class="nav-link-title">Forms</span></a></li>
              <li class="nav-item <%= activeTab === 'visitation' ? 'active' : '' %>"><a class="nav-link" href="/visitation"><span class="nav-link-title">Visitation</span></a></li>
              <% if (isAdmin) { %>
                <li class="nav-item <%= activeTab === 'church_settings' ? 'active' : '' %>"><a class="nav-link" href="/settings/church"><span class="nav-link-title">Church Settings</span></a></li>
              <% } %>
              <li class="nav-item <%= activeTab === 'import' ? 'active' : '' %>"><a class="nav-link" href="/import"><span class="nav-link-title">Import</span></a></li>
            </ul>
          </div>
        </div>
      </div>
    </header>

    <div class="page-wrapper">
      <div class="container-xl py-3">
